{
  "tasks": {
    "run": "deno run --allow-read --allow-write --allow-env --allow-net --check src/main.ts",
    "fmt": "deno fmt src/",
    "dist": {"dependencies": ["dist-bundle", "dist-linux", "dist-windows"]},
    "dist-bundle": "deno bundle --check --output dist/asset_janny_$TAG.js src/main.ts",
    "dist-linux": "deno compile --allow-read --allow-write --allow-env --allow-net --check --target x86_64-unknown-linux-gnu --output dist/asset_janny_linux_x86_64_$TAG src/main.ts",
    "dist-windows": "deno compile --allow-read --allow-write --allow-env --allow-net --check --target x86_64-pc-windows-msvc --output dist/asset_janny_windows_x86_64_$TAG.exe src/main.ts"
  }
}
